# Browser GraphQL endpoint (proxied via next.config rewrites)
NEXT_PUBLIC_GRAPHQL_URL=/graphql
# Server-side GraphQL endpoint (direct backend URL)
GRAPHQL_SSR_URL=http://localhost:3002/graphql
# Public REST API base URL (vendor product import, etc.; defaults to http://localhost:3002)
# NEXT_PUBLIC_API_URL=http://localhost:3002

# Optional: override GraphQL schema path for codegen (default: ../sopet-backend/src/schema.gql)
# GRAPHQL_SCHEMA_PATH=../sopet-backend/src/schema.gql
