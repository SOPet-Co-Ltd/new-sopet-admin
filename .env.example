# Browser GraphQL endpoint (proxied via next.config rewrites)
NEXT_PUBLIC_GRAPHQL_URL=/graphql
# Server-side GraphQL endpoint (direct backend URL)
GRAPHQL_SSR_URL=http://localhost:3002/graphql
# Public REST API base URL for vendor API docs / llms.txt (no trailing slash).
# Required in deployed envs — use the same public HTTPS API host as GraphQL (without /graphql).
# Example: https://api-uat.sopet.org
# NEXT_PUBLIC_API_URL=https://api.sopet.org

# Public CDN base URL for uploaded images (must match backend CDN_URL in deployed envs)
# NEXT_PUBLIC_CDN_URL=https://pub-<hash>.r2.dev

# Optional: override GraphQL schema path for codegen (default: ../sopet-backend/src/schema.gql)
# GRAPHQL_SCHEMA_PATH=../sopet-backend/src/schema.gql
# Vercel/CI: fetched from GitHub when local schema is missing (see scripts/ensure-graphql-schema.mjs)
# GRAPHQL_SCHEMA_GITHUB_OWNER=
# GRAPHQL_SCHEMA_GITHUB_REPO=new-sopet-backend
# GRAPHQL_SCHEMA_GITHUB_REF=main
